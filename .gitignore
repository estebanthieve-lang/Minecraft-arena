# Herramientas/cache pesadas que se descargan localmente
tools/*
!tools/
!tools/python-embed/
!tools/python-embed/**
downloads/
tmp/
backups/

# Documentacion interna del proyecto
*.md
!RELEASE_CHECKLIST.md

# Build/cache del mod Forge
game/
game/mod-src/.gradle/
game/mod-src/build/
game/mod-src/run/
scripts/compilar_mod_arena.ps1
scripts/hacer_op.ps1

# Python/cache runtime
runtime/__pycache__/
*.pyc

# Datos vivos del juego y usuario
data/
logs/
saves/
user-data/

# Servidor Forge generado localmente
server/libraries/
server/versions/
server/world/
server/logs/
server/crash-reports/
server/config/
server/defaultconfigs/
server/easy_npc/
server/mods/
server/*.jar
server/*.log
server/installer.log
server/run.bat
server/run.sh
server/user_jvm_args.txt
server/usercache.json
server/usernamecache.json
server/banned-ips.json
server/banned-players.json
server/ops.json
server/whitelist.json

# Mods entregables: solo el mod propio
/mods/*
!/mods/
!/mods/minecraft_live_arena-*.jar
/dist/mods/*
!/dist/
!/dist/mods/
!/dist/mods/minecraft_live_arena-*.jar

# Archivos temporales de inspeccion
tmp_*.txt

# Herramientas internas: solo se entrega el instalador de cliente
HERRAMIENTAS_DEV/*
!HERRAMIENTAS_DEV/
!HERRAMIENTAS_DEV/INSTALAR_Y_ABRIR_TIKTOK_MINECRAFT.cmd
